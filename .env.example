# Site
NEXT_PUBLIC_SITE_URL=https://gardianlogistics.in

# Database — use PostgreSQL (Neon, Vercel Postgres, or Supabase) for production
# Local example (Neon): postgresql://user:pass@host/db?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Google OAuth — customers & agents sign in via Gmail
# Create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=generate_a_random_secret_here

# Role assignment by Gmail (optional fallback for Google sign-in)
ADMIN_EMAILS=admin@gmail.com
SUB_ADMIN_EMAILS=subadmin@gmail.com

# Staff login via Company ID (admin & sub-admin — no Google required)
ADMIN_COMPANY_ID=GL-ADMIN-001
ADMIN_PASSWORD=change_this_admin_password
ADMIN_STAFF_EMAIL=admin@gardianlogistics.in
SUB_ADMIN_COMPANY_ID=GL-SUBADMIN-001
SUB_ADMIN_PASSWORD=change_this_subadmin_password
SUB_ADMIN_STAFF_EMAIL=subadmin@gardianlogistics.in

# Tracking API (plug in real courier partner credentials)
USE_MOCK_TRACKING=true
COURIER_API_KEY=your_api_key_here
COURIER_API_BASE_URL=https://api.your-courier-partner.com/v1

# Rate limiting (requests per window per IP)
TRACK_RATE_LIMIT=20
TRACK_RATE_WINDOW_MS=60000

# Contact / Quote (wire up email or database later)
CONTACT_EMAIL=info@gardianlogistics.in
